# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# DeepFocus / focalstack specific
runs/
runs_gm/
data/
*.pth
*.exr
*.tar.gz
*.zip
*.png

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# VS Code / IDE
.vscode/
.idea/
*.swp
*.swo

# MacOS
.DS_Store
